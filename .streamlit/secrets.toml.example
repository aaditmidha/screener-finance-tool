# Streamlit secrets template.
#
# Local use:   copy this file to .streamlit/secrets.toml (gitignored) and fill in.
# Cloud use:   paste the same contents into the app's "Secrets" box in the
#              Streamlit Community Cloud dashboard (App → Settings → Secrets).

# Groq API key — free tier at https://console.groq.com/keys
# (Project policy: all LLM calls use Groq, never the Anthropic API.)
GROQ_API_KEY = "gsk_your_key_here"
